{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@sandchest/gateway#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "@sandchest/web#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "//#compose:down": {
      "cache": false
    },
    "//#compose:up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "gateway:dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "outputs": []
    }
  }
}
