{
  "name": "sandchest",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "compose:down": "docker compose down",
    "compose:up": "docker compose up -d postgres redis",
    "dev": "turbo dev",
    "gateway:dev": "turbo gateway:dev --filter=@sandchest/gateway",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  }
}
